# InvestGuideUA — environment template (X2). Copy to `.env` and fill in real values.
# NEVER commit the populated `.env`. Secrets are read from the environment only and must never
# appear in source, logs, or the frontend bundle (SPECIFICATION §10, X2 DoD).

# ----- Secrets (REQUIRED — app fails fast at startup if any is missing) -----
# Anthropic Claude API key (server-side LLM calls only; §8.1)
ANTHROPIC_API_KEY=

# monobank "Plata by mono" merchant token / X-Token (server-side only; §9).
# Obtain from the merchant web cabinet at https://web.monobank.ua/ (or a test token from
# https://api.monobank.ua/ for sandbox). OPTIONAL at startup: leave blank to run a working app
# (needed to onboard with the bank); payment creation returns 502 until this is set.
MONO_TOKEN=

# JWT signing secret — must be at least 32 bytes (HS256). Generate in PowerShell:
#   $b=[byte[]]::new(48);[System.Security.Cryptography.RandomNumberGenerator]::Create().GetBytes($b);[Convert]::ToBase64String($b)
# (or just run .\scripts\setup-env.ps1, which fills this in automatically)
JWT_SECRET=

# MongoDB connection string (with credentials in prod). In Docker Compose this is overridden
# to mongodb://mongo:27017/investguide by the compose file.
MONGODB_URI=mongodb://localhost:27017/investguide

# ----- Non-secret config (have defaults; override as needed) -----
SERVER_PORT=8080

# CORS allow-origin — the single app origin (§10). Set to the deployed SPA origin in prod.
APP_CORS_ALLOWED_ORIGIN=http://localhost:8081

# SPA base URL — used to build the email-verification link (BE-A3). Set to the deployed SPA origin.
APP_FRONTEND_BASE_URL=http://localhost:8081

# Refresh-token cookie attributes (BE-A4 / FE-CORE2). Production behind TLS keeps these as-is
# (Secure + SameSite=None for a cross-origin SPA). For plain-HTTP local dev WITHOUT a TLS proxy,
# set secure=false and same-site=Lax so the browser will store and send the cookie.
APP_REFRESH_COOKIE_SECURE=true
APP_REFRESH_COOKIE_SAMESITE=None

# Payment redirect/callback URLs (§9.2)
PAYMENT_RESULT_URL=http://localhost:8081/payments/result
PAYMENT_CALLBACK_URL=http://localhost:8080/api/v1/payments/mono/callback

# ----- Email / SMTP (OPTIONAL - app builds, starts, and registers users without these; 003) -----
# Leave MAIL_ENABLED=false (default) to run with verification email disabled: registration still
# works and a descriptive line is logged at startup. Set MAIL_ENABLED=true AND fill host/from/creds
# to actually send. Incomplete config (enabled but host/from blank) degrades to disabled + a WARN.
# MAIL_USERNAME / MAIL_PASSWORD are secrets - env only, never logged. Do NOT set spring.mail.* /
# SPRING_MAIL_* (that would re-activate Spring's auto-config and create a second mail sender).
MAIL_ENABLED=false
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=
MAIL_START_TLS=true
# DEV ONLY: print the verification link to the logs when email is disabled. NEVER true in prod.
MAIL_LOG_LINK=false

# ----- Local dev seed user (DEV ONLY - NEVER true in prod) -----
# When true, DevUserSeeder inserts a predefined, ready-to-login account on startup:
#   email: dev@investguide.local   password: devpassword123   (verified, 5 tokens)
# The password is a well-known fixture, so this MUST stay false anywhere internet-reachable.
# The Docker Compose stack already sets this to true for you; only needed here for the
# bare-metal `mvn spring-boot:run` path against a local MongoDB.
APP_SEED_DEV_USER_ENABLED=false

# ----- Tunable [CONFIG] (optional overrides; defaults in application.yml) -----
# APP_SIGNUP_FREE-TOKENS=5
# APP_RATE_SIGNUP-PER-HOUR-PER-IP=10
# APP_RATE_SEARCH-PER-MINUTE=5
# APP_SEARCH_MAX-AMOUNT=100000000
# APP_SEARCH_MAX-OPTIONS=5
# LLM_MAX-INPUT-TOKENS=3000
# LLM_MAX-OUTPUT-TOKENS=700
# LLM_TEMPERATURE=0.4
# LLM_REQUEST-TIMEOUT-MS=7000
# SECURITY_ACCESS-TTL-MS=900000
# SECURITY_REFRESH-TTL-MS=1209600000
