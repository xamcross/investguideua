# Cloudflare Pages cache policy (feature 006 / ticket FE-CORE5).
#
# HTML entry points MUST always revalidate. index.html lists the current content-hashed JS/CSS
# chunks; if a stale copy is served after a deploy it points at chunk URLs the new build removed,
# which 404s lazy routes ("Failed to fetch dynamically imported module"). max-age=0 +
# must-revalidate makes the browser/CDN re-check on every load so a deploy takes effect at once.
/
  Cache-Control: public, max-age=0, must-revalidate
/*.html
  Cache-Control: public, max-age=0, must-revalidate

# Content-hashed build artifacts never change for a given name, so cache them aggressively. A new
# build emits new filenames rather than mutating these, so "immutable" is safe and cuts refetches.
/*.js
  Cache-Control: public, max-age=31536000, immutable
/*.css
  Cache-Control: public, max-age=31536000, immutable
